# Deny direct access to all files in the project root.
# The web server should only ever serve /public. This file is a
# safety net in case the document root is mistakenly pointed at the
# project root (or at ~/public_html) instead of ~/jobboard/public.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
</IfModule>

# Belt and braces: explicitly block common sensitive paths even if
# directory listing accidentally becomes enabled.
<FilesMatch "(^\.|composer\.(json|lock)|package(-lock)?\.json|\.env|\.env\..*|artisan|yarn\.lock|\.git|\.gitignore|\.gitattributes|README\.md|AGENTS\.md|CHANGELOG\.md|vendor/)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Disable directory browsing.
Options -Indexes
