# Production environment template for cPanel (jobs.focusednet.com)
# ----------------------------------------------------------------
# 1. Copy this file to .env on the server (cp .env.production.example .env)
# 2. Fill in DB_*, MAIL_*, and regenerate APP_KEY with:
#       php artisan key:generate --force
# 3. Run the steps in DEPLOY_TO_CPANEL.md
#
# On cPanel shared hosting, MySQL "localhost" is correct; the DB
# host cPanel reports in the Databases panel is "localhost" even
# though the daemon is on the same box. Use 127.0.0.1 only if your
# host explicitly documents that.

APP_NAME="JobFinder"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://jobs.focusednet.com

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning
LOG_DEPRECATIONS_CHANNEL=null

# --- Database (cPanel MySQL/MariaDB) ----------------------------
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=cpanelusername_jobboard
DB_USERNAME=cpanelusername_jbuser
DB_PASSWORD=replace_with_strong_password

# --- Cache / Session / Queue ------------------------------------
# On shared hosting prefer the `file` driver. Use `redis` only if
# you provisioned Redis through cPanel.
BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.focusednet.com

# --- Mail (cPanel email account or external SMTP) ---------------
# Option A — cPanel mail account (replace host with the server's
# mail server, often the domain itself):
# MAIL_MAILER=smtp
# MAIL_HOST=mail.focusednet.com
# MAIL_PORT=465
# MAIL_USERNAME=noreply@jobs.focusednet.com
# MAIL_PASSWORD=replace
# MAIL_ENCRYPTION=ssl
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS="noreply@jobs.focusednet.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Misc --------------------------------------------------------
BCRYPT_ROUNDS=10

VITE_APP_NAME="${APP_NAME}"
